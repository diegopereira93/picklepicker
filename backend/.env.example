# PickleIQ Backend — Environment Variables
# Copy this file to .env and fill in your values

# === Required ===

# PostgreSQL connection string
# Local: postgresql://pickleiq:changeme@localhost:5432/pickleiq
# Production: Supabase connection string
DATABASE_URL=

# Groq API key for chat LLM (https://console.groq.com)
GROQ_API_KEY=

# Jina AI API key for embeddings (https://jina.ai/api-dashboard)
JINA_API_KEY=

# === Optional ===

# Embedding provider: "jina" (default) or "huggingface"
EMBEDDING_PROVIDER=

# Hugging Face API key (fallback embeddings)
# HUGGINGFACE_API_KEY=

# Firecrawl API key for web scraping (https://firecrawl.dev)
# FIRECRAWL_API_KEY=

# Gemini API key (alternative LLM)
# GEMINI_API_KEY=

# Clerk authentication (frontend)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# Resend email API key
# RESEND_API_KEY=

# Telegram error alerting
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Admin endpoint Bearer token (self-generated)
# ADMIN_SECRET=
