# PostgreSQL (local Docker)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pickleiq
POSTGRES_USER=pickleiq
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://pickleiq:changeme@localhost:5432/pickleiq

# Supabase staging
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon_key>
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>
SUPABASE_DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# Production (Supabase Pro with pgvector)
# DATABASE_URL=postgresql://postgres:[password]@db.[region].supabase.co:5432/postgres?pool_size=10&max_overflow=20&sslmode=require
# SUPABASE_URL=https://[project].supabase.co
# SUPABASE_ANON_KEY=[public-key]

# Firecrawl
FIRECRAWL_API_KEY=fc-<key>

# Mercado Livre Afiliados
ML_AFFILIATE_TAG=<your_tag_id>

# Telegram alerts
TELEGRAM_BOT_TOKEN=<bot_token>
TELEGRAM_CHAT_ID=<chat_id>

# Phase 2 — Crawlers Configuration
ML_API_BATCH_SIZE=50
ML_API_MAX_PAGES=10
FIRECRAWL_TIMEOUT_SEC=30

# Phase 3 — LLM & Observability (set in Railway, not committed)
GROQ_API_KEY=gsk_<key>
LANGFUSE_SECRET_KEY=sk-lf-<key>

# Frontend environment variables (set in Vercel dashboard)
# STAGING: Railway API endpoint (auto-generated domain pattern: https://[project]-[env]-[random].railway.app)
NEXT_PUBLIC_FASTAPI_URL=https://api.railway.app
# PRODUCTION: Use pickleiq.com (Phase 07)
# NEXT_PUBLIC_FASTAPI_URL=https://api.pickleiq.com
NEXT_PUBLIC_LANGFUSE_KEY=pk-<key>
