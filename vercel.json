{
  "version": 2,
  "env": {
    "NEXT_PUBLIC_FASTAPI_URL": {
      "description": "FastAPI backend URL (set in Vercel Dashboard)"
    },
    "NEXT_PUBLIC_LANGFUSE_KEY": {
      "description": "Langfuse public key for tracing (set in Vercel Dashboard)"
    },
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY": {
      "description": "Clerk public key for auth (set in Vercel Dashboard - get from Clerk Dashboard)"
    },
    "CLERK_SECRET_KEY": {
      "description": "Clerk secret key for auth (set in Vercel Dashboard - get from Clerk Dashboard)"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.railway.app/api/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/admin/(.*)",
      "destination": "https://picklepicker.vercel.app/admin/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,DELETE,PATCH,POST,PUT"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version"
        }
      ]
    }
  ],
  "build": {
    "env": {
      "NEXT_PUBLIC_FASTAPI_URL": "@changeme",
      "NEXT_PUBLIC_LANGFUSE_KEY": "@changeme",
      "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY": "@changeme",
      "CLERK_SECRET_KEY": "@changeme"
    }
  }
}
